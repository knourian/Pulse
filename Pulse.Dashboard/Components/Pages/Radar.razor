@page "/radar"
@rendermode InteractiveServer
@attribute [Authorize]

@using Pulse.Contracts.CheckRuns
@using Pulse.Dashboard.Services.CheckResults

@implements IDisposable

@inject ICheckResultService CheckResultService

<PageTitle>Radar</PageTitle>

<h1>Radar</h1>

<div class="mb-3">

    <button class="btn btn-primary"
            @onclick="ReloadAsync"
            disabled="@_isLoading">

        @(_isLoading ? "Loading..." : "Refresh")

    </button>

</div>

@if (_isLoading)
{
    <div class="d-flex align-items-center gap-2">

        <div class="spinner-border spinner-border-sm"></div>

        <span>Loading radar data...</span>

    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">
        @_error
    </div>
}
else if (_checks.Count == 0)
{
    <div class="alert alert-info">
        No radar data found.
    </div>
}
else
{
    <div class="table-responsive">

        <table class="table table-bordered align-middle">

            <thead class="table-light">

                <tr>

                    <th class="sticky-check-column bg-light" style="min-width:150px;">
                        Check
                    </th>

                    @foreach (var agent in _agents)
                    {
                        <th style="min-width: 200px;">

                            <div class="fw-semibold">
                                <span style="padding:0 3px">@agent.AgentName</span>
                                @if (agent.IsOnline)
                                {
                                    <span class="d-inline-block rounded-circle bg-success"
                                          style="width:12px; height:12px;"
                                          title="Online">
                                    </span>
                                }
                                else
                                {
                                    <span class="d-inline-block rounded-circle bg-danger"
                                          style="width:12px; height:12px;"
                                          title="Offline">
                                    </span>
                                }
                            </div>

                            <small class="text-muted">

                                Last Seen: @agent.LastHeartbeatUtc.ToString("HH:mm:ss")

                            </small>

                        </th>
                    }

                </tr>

            </thead>

            <tbody>

                @foreach (var check in _checks)
                {
                    <tr>

                        <td class="sticky-check-column bg-white">

                            <div class="fw-semibold">
                                @check.CheckName
                            </div>

                            <small class="text-muted" style="font-size: xx-small;">
                                @check.CheckId
                            </small>

                        </td>

                        @foreach (var agent in _agents)
                        {
                            var agentResult = check.Agents
                                .FirstOrDefault(x => x.AgentId == agent.AgentId);

                            <td>

                                @if (agentResult == null)
                                {
                                    <span class="badge text-bg-secondary">
                                        No Data
                                    </span>
                                }
                                else
                                {
                                    <div class="d-flex flex-column gap-2">

                                        <div class="d-flex gap-1 flex-wrap">

                                            @foreach (var result in agentResult.Results
                                                .OrderByDescending(x => x.TimestampUtc))
                                            {
                                                <div class="border rounded p-2 text-center d-flex flex-column justify-content-between align-items-center"
                                                     style="width:90px; height:72px;">

                                                    @if (result.IsSuccess)
                                                    {
                                                        <span class="badge text-bg-success">
                                                            Up
                                                        </span>

                                                        <small class="text-muted text-nowrap">
                                                            @result.ResponseTimeMs ms
                                                        </small>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge text-bg-danger">
                                                            Down
                                                        </span>

                                                        <small class="text-muted text-truncate w-100"
                                                               title="@result.Error">

                                                            @result.Error

                                                        </small>
                                                    }

                                                </div>
                                            }

                                        </div>

                                    </div>
                                }

                            </td>
                        }

                    </tr>
                }

            </tbody>

        </table>

    </div>
}

@code {

    private IReadOnlyList<RadarCheckDto> _checks = [];

    private IReadOnlyList<RadarAgentDto> _agents = [];

    private bool _isLoading;

    private string _error;

    private CancellationTokenSource _loadCts;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loadCts?.Cancel();
        _loadCts?.Dispose();

        _loadCts = new CancellationTokenSource();

        _isLoading = true;

        _error = null;

        try
        {
            _checks = await CheckResultService.GetRadarAsync(_loadCts.Token);

            _agents = _checks.SelectMany(x => x.Agents)
                             .DistinctBy(x=> x.AgentId)
                             .OrderBy(x => x.LastHeartbeatUtc)
                             .ToList();
        }
        catch (OperationCanceledException)
        {
            // Ignore cancellation
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    public void Dispose()
    {
        _loadCts?.Cancel();
        _loadCts?.Dispose();
    }
}