@page "/radar"
@rendermode InteractiveServer

@using Pulse.Contracts.CheckRuns
@using Pulse.Dashboard.Services.CheckResults

@implements IDisposable

@inject ICheckResultService CheckResultService

<PageTitle>Radar</PageTitle>

<h1>Radar</h1>

<div class="mb-3">

    <button class="btn btn-primary"
            @onclick="ReloadAsync"
            disabled="@_isLoading">

        @(_isLoading ? "Loading..." : "Refresh")

    </button>

</div>

@if (_isLoading)
{
    <div class="d-flex align-items-center gap-2">

        <div class="spinner-border spinner-border-sm"></div>

        <span>Loading radar data...</span>

    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">
        @_error
    </div>
}
else if (_checks.Count == 0)
{
    <div class="alert alert-info">
        No radar data found.
    </div>
}
else
{
    <div class="table-responsive">

        <table class="table table-bordered align-middle">

            <thead class="table-light">

                <tr>

                    <th style="min-width: 240px;">
                        Check
                    </th>

                    @foreach (var agent in _agents)
                    {
                        <th class="text-center">
                            @agent
                        </th>
                    }

                </tr>

            </thead>

            <tbody>

                @foreach (var check in _checks)
                {
                    <tr>

                        <td>

                            <div class="fw-semibold">
                                @check.CheckName
                            </div>

                            <small class="text-muted">
                                @check.CheckId
                            </small>

                        </td>

                        @foreach (var agent in _agents)
                        {
                            var result = check.Agents
                                .FirstOrDefault(x => x.AgentName == agent);

                            <td class="text-center">

                                @if (result == null)
                                {
                                    <span class="badge text-bg-secondary">
                                        No Data
                                    </span>
                                }
                                else if (result.IsSuccess)
                                {
                                    <div>

                                        <span class="badge text-bg-success">
                                            Up
                                        </span>

                                    </div>

                                    <small class="text-muted">
                                        @result.ResponseTimeMs ms
                                    </small>
                                }
                                else
                                {
                                    <div>

                                        <span class="badge text-bg-danger">
                                            Down
                                        </span>

                                    </div>

                                    <small class="text-muted">
                                        @result.Error
                                    </small>
                                }

                            </td>
                        }

                    </tr>
                }

            </tbody>

        </table>

    </div>
}

@code {

    private IReadOnlyList<RadarCheckDto> _checks = [];

    private IReadOnlyList<string> _agents = [];

    private bool _isLoading;

    private string _error;

    private CancellationTokenSource _loadCts;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loadCts?.Cancel();
        _loadCts?.Dispose();

        _loadCts = new CancellationTokenSource();

        _isLoading = true;

        _error = null;

        try
        {
            _checks = await CheckResultService.GetRadarAsync(
                _loadCts.Token);

            _agents = _checks
                .SelectMany(x => x.Agents)
                .Select(x => x.AgentName)
                .Distinct()
                .OrderBy(x => x)
                .ToList();
        }
        catch (OperationCanceledException)
        {
            // Ignore cancellation
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    public void Dispose()
    {
        _loadCts?.Cancel();
        _loadCts?.Dispose();
    }
}